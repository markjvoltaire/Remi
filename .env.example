# === Required ===
ANTHROPIC_API_KEY=sk-ant-.         # Claude API key (anthropic.com)
BLOOIO_API_KEY=
BLOOIO_PHONE_NUMBER=
BLOOIO_WEBHOOK_SECRET=

# === Storage (Supabase) ===
STORAGE_PROVIDER=supabase            # supabase (recommended) or dynamodb
SUPABASE_URL=                       # e.g. https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=         # service role key (server-side only)

# === Resy ===
RESY_API_KEY=VbWk7s3L4KiK5fzlO7JD3Q5EYolJI7n5   # Public Resy API key (embedded in their frontend)
RESY_AUTH_TOKEN=                                   # Optional shared Resy JWT: skips partner OTP for all guests (dev/demo ONLY; never in production). Each guest still has their own chat thread and history.
RESY_USE_SHARED_TOKEN=                             # Deprecated — no longer required; presence of RESY_AUTH_TOKEN alone enables shared mode
PAYMENT_SETUP_URL=                                 # optional; stable login when a card must be on file (default https://resy.com/login). Override e.g. for a hosted vault flow.

# === Remi Vault (Stripe Forwarding) ===
STRIPE_SECRET_KEY=                                 # server-only; Payment Forwarding to inject vaulted card into allowlisted endpoints
RESY_FORWARD_BOOK_URL=                             # optional; default https://api.resy.com/3/book — must match Stripe forwarding allowlist

# === Auth / Security ===
BASE_URL=http://localhost:3000         # Public https URL for magic links when REM_MAGIC_LINK_ONBOARDING is enabled
REM_MAGIC_LINK_ONBOARDING=             # Set to 1/true to use magic link before SMS; leave unset for Resy SMS OTP (default)
CREDENTIAL_ENCRYPTION_KEY=             # 64 hex chars — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# === Cloud browser (payment handoff) ===
CLOUD_BROWSER_ENABLED=false                    # feature flag; off by default
BROWSERBASE_API_KEY=                           # bb_live_...
BROWSERBASE_PROJECT_ID=                        # prj_...
CLOUD_BROWSER_SESSION_TIMEOUT_MS=900000        # 15 min default live-view window

# === Optional ===
PORT=3000
NODE_ENV=development
ALLOWED_SENDERS=                       # Lock to specific numbers during dev (comma-separated)
IGNORED_SENDERS=                       # Numbers to ignore (comma-separated)
