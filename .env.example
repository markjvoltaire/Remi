# === Required ===
ANTHROPIC_API_KEY=sk-ant-...          # Claude API key (anthropic.com)
BLOOIO_API_KEY=
BLOOIO_PHONE_NUMBER=
BLOOIO_WEBHOOK_SECRET=

# === Storage (Supabase) ===
STORAGE_PROVIDER=supabase            # supabase (recommended) or dynamodb
SUPABASE_URL=                       # e.g. https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=         # service role key (server-side only)

# === Resy ===
RESY_API_KEY=VbWk7s3L4KiK5fzlO7JD3Q5EYolJI7n5   # Public Resy API key (embedded in their frontend)
RESY_AUTH_TOKEN=                                   # Your Resy JWT — skips per-user onboarding when set (grab from resy.com devtools)

# === Auth / Security ===
BASE_URL=http://localhost:3000         # Public URL for magic link generation
CREDENTIAL_ENCRYPTION_KEY=             # 64 hex chars — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# === Optional ===
PORT=3000
NODE_ENV=development
ALLOWED_SENDERS=                       # Lock to specific numbers during dev (comma-separated)
IGNORED_SENDERS=                       # Numbers to ignore (comma-separated)
